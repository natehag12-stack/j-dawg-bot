# Copy this file to .env and fill in your values

# --- Telegram (required) ---
TELEGRAM_TOKEN=paste_your_botfather_token_here
TELEGRAM_CHAT_ID=paste_your_numeric_chat_id_here

# --- Market ---
# SYMBOL is the legacy single-symbol setting.
# SYMBOLS overrides it — comma-separated list watched in parallel.
# Common tickers: NQ=F (NASDAQ 100 futures), QQQ (ETF), ^NDX (index), ES=F (S&P futures)
SYMBOL=NQ=F
SYMBOLS=NQ=F,QQQ

# --- Paper trading ---
# When true, every fired signal opens a paper position and pushes both an OPEN
# notification and a CLOSE notification (with P&L in ticks) when it resolves.
PAPER_TRADING=true

# --- Alert gating ---
# Static minimum Bayesian posterior required to alert (used when ADAPTIVE_THRESHOLD=false).
MIN_POSTERIOR_TO_ALERT=0.45

# --- Self-learning / adaptive threshold ---
# When true, the bot maintains a per-(symbol, side) confidence threshold that
# rises after losing streaks and falls after winning streaks, bounded by
# ADAPTIVE_MIN / ADAPTIVE_MAX.
ADAPTIVE_THRESHOLD=true
ADAPTIVE_MIN=0.40
ADAPTIVE_MAX=0.75
ADAPTIVE_WINDOW=20
ADAPTIVE_STEP=0.02

# --- Loop ---
POLL_INTERVAL_SECONDS=60

# --- Daily P&L recap ---
# ET time to push the daily summary to Telegram (24h format).
DAILY_SUMMARY_TIME=16:15
