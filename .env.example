# Copy this file to .env and fill in your values

# --- Telegram (required) ---
TELEGRAM_TOKEN=paste_your_botfather_token_here
TELEGRAM_CHAT_ID=paste_your_numeric_chat_id_here

# --- Market ---
# SYMBOL is the legacy single-symbol setting.
# SYMBOLS overrides it — comma-separated list watched in parallel.
# Common tickers: NQ=F (NASDAQ 100 futures), QQQ (ETF), ^NDX (index), ES=F (S&P futures)
SYMBOL=NQ=F
SYMBOLS=NQ=F,QQQ

# --- Alert gating ---
# Minimum Bayesian posterior confidence required to actually send an alert.
# Starts at 0.5 (neutral). Bot adapts this internally as it learns from wins/losses.
MIN_POSTERIOR_TO_ALERT=0.45

# --- Loop ---
POLL_INTERVAL_SECONDS=60

# --- Daily P&L recap ---
# ET time to push the daily summary to Telegram (24h format).
DAILY_SUMMARY_TIME=16:15
